# ===== Hub Service Runtime Template =====
#
# This file is for packaged or managed Hub service startup.
# Use it together with scripts/starter.sh:
#
#   cp config/hub.env.template config/hub.env
#   edit config/hub.env
#   bash scripts/starter.sh start

# Bind address for web UI + APIs.
HUB_BIND_ADDR=127.0.0.1:3900

# Optional overrides for packaged/service runtime.
# Usually keep these defaults unless the install path or runtime path is customized.
# HUB_REPO_ROOT=/home/administrator/code/robot
# HUB_RUNTIME_DIR=/home/administrator/code/robot/runtime/control-plane
# HUB_INSTANCES_ROOT=/home/administrator/code/robot/runtime/instances

# Public base URL used in wallet challenge text.
# Leave empty for local/private deployment without a fixed external URL.
HUB_PUBLIC_BASE_URL=

# Router upstream.
ROUTER_BASE_URL=https://test-router.yeying.pub/v1
ROUTER_API_KEY=

# Default model and allowlist exposed by Hub.
# The default model can also be changed from the UI/API.
HUB_DEFAULT_MODEL=gpt-5.3-codex
HUB_MODEL_ALLOWLIST=gpt-5.3-codex,gpt-5.1-mini

# Wallet auth settings.
HUB_CHALLENGE_TTL_SECONDS=300
HUB_SESSION_TTL_SECONDS=86400

# Replace this in any shared or real deployment.
HUB_SESSION_SECRET=change-me-control-plane-session-secret

# Cookie secure mode:
# - auto: infer from request/proxy headers
# - always: always set Secure
# - never: never set Secure
HUB_SESSION_COOKIE_SECURE_MODE=auto

# Port range allocated to managed OpenClaw instances.
HUB_INSTANCE_PORT_START=18800
HUB_INSTANCE_PORT_END=18999

# Reserved tokens for admin/internal routes.
HUB_ADMIN_TOKEN=change-me-admin-token
HUB_INTERNAL_TOKEN=change-me-internal-token

# Optional command prefix for launching openclaw.
# Useful when outbound traffic must go through a local proxy wrapper.
# Example: HUB_OPENCLAW_PREFIX=proxychains4 -q
HUB_OPENCLAW_PREFIX=""
