# ===== Hub Backend Local Development Template =====
#
# Local development:
#   cp hub/backend/.env.template hub/backend/.env
#
# `.env` is for local backend startup only and must not be committed.

# Local backend bind address.
HUB_BIND_ADDR=127.0.0.1:3900

# Optional absolute repo root.
# Usually leave empty and let hub/backend infer it from the current directory.
# HUB_REPO_ROOT=/Users/yourname/Workspace/opensource/robot

# Optional local runtime paths.
# HUB_RUNTIME_DIR=/Users/yourname/Workspace/opensource/robot/runtime/control-plane
# HUB_INSTANCES_ROOT=/Users/yourname/Workspace/opensource/robot/runtime/instances

# Public URL used in wallet challenge text.
# Keep empty for plain local development.
HUB_PUBLIC_BASE_URL=

# Router upstream.
ROUTER_BASE_URL=https://test-router.yeying.pub/v1
ROUTER_API_KEY=

# Model defaults exposed by Hub.
HUB_DEFAULT_MODEL=gpt-5.3-codex
HUB_MODEL_ALLOWLIST=gpt-5.3-codex,gpt-5.1-mini

# Wallet auth settings.
HUB_CHALLENGE_TTL_SECONDS=300
HUB_SESSION_TTL_SECONDS=86400

# Local-only secret for signed session/challenge payloads.
HUB_SESSION_SECRET=change-me-control-plane-session-secret

# For local http development, `never` avoids Secure-cookie issues.
# Supported values: auto / always / never
HUB_SESSION_COOKIE_SECURE_MODE=never

# Port range allocated to managed OpenClaw instances.
HUB_INSTANCE_PORT_START=18800
HUB_INSTANCE_PORT_END=18999

# Reserved tokens for admin/internal routes.
HUB_ADMIN_TOKEN=change-me-admin-token
HUB_INTERNAL_TOKEN=change-me-internal-token

# Optional command prefix for launching openclaw.
# Example:
# HUB_OPENCLAW_PREFIX=proxychains4 -q
HUB_OPENCLAW_PREFIX=
