# =========================
# Coder Bot 配置模板
# =========================
# 用法：
# 1. 复制本文件为 config/coder-bot.env
# 2. 按注释填写自己的值
# 3. 运行 ./scripts/bootstrap.sh 或重启服务

# -------------------------
# 路径基准
# -------------------------
APP_HOME=..
DATA_DIR=data
SECRETS_DIR=secrets
LOG_DIR=data/logs

# -------------------------
# 服务监听地址
# -------------------------
LISTEN_HOST=0.0.0.0
LISTEN_PORT=9081

# -------------------------
# GitHub App
# -------------------------
GITHUB_APP_ID=
GITHUB_INSTALLATION_ID=
GITHUB_FORK_INSTALLATION_ID=
GITHUB_PRIVATE_KEY_PATH=secrets/github-app.pem
GITHUB_CLONE_SSH_KEY_PATH=secrets/github-push-key
GITHUB_FORK_OWNER=your-github-name

# -------------------------
# 允许处理的仓库
# -------------------------
# 多个仓库用英文逗号分隔
# 示例：
# ALLOWED_REPOS=yeying-community/deployer,yeying-community/robot
ALLOWED_REPOS=upstream-owner/repo-name
# 可选：给 `/issue <repo>` 命令补充别名映射
# REPO_ALIASES=deployer=yeying-community/deployer,robot=yeying-community/robot

# -------------------------
# 执行后端
# -------------------------
# 默认后端只在未显式选模型时生效。
# 飞书里发送 `/model gpt-5.5`、`/model claude-opus-4-6` 时，后端会自动按模型推断。
EXECUTION_BACKEND=codex
ISSUE_SESSION_PREFIX=gh
CODEX_BIN=codex
CODEX_MODEL=
SUPPORTED_CODEX_MODELS=gpt-5.2,gpt-5.3-codex,gpt-5.4,gpt-5.4-mini,gpt-5.5
CODEX_TIMEOUT=3600
CODEX_SOURCE_HOME=~/.codex
CODEX_RUNTIME_HOME=data/codex/home
CODEX_USE_DANGEROUSLY_BYPASS=true
CLAUDE_BIN=claude
CLAUDE_MODEL=claude-opus-4-6
SUPPORTED_CLAUDE_MODELS=claude-haiku-4-5-20251001,claude-opus-4-6,claude-opus-4-6-thinking,claude-opus-4-7,claude-sonnet-4-6
CLAUDE_TIMEOUT=3600
ISSUE_BRANCH_PREFIX=coder

# -------------------------
# Feishu handoff
# -------------------------
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_HANDOFF_CHAT_ID=
# 多个顶层群入口用英文逗号分隔；在哪个群发 `/issue <repo>`，就在哪个群继续线程。
FEISHU_HANDOFF_CHAT_IDS=
FEISHU_CONFIRM_KEYWORDS=/run,开始执行,确认执行,可以执行,方案1,方案一,执行方案1,执行方案一
FEISHU_CHAT_SCAN_LIMIT=30
FEISHU_THREAD_SCAN_LIMIT=30

# -------------------------
# 运行数据目录
# -------------------------
DB_PATH=data/issue_bot.db
JOB_ROOT=data/jobs
REPO_ROOT=data/repos
REPO_LOCK_WAIT_SECONDS=7200
ACTIVE_DIR=data/active
STATE_FILE=data/state.json
SYNC_SCRIPT_PATH=scripts/sync.sh

# -------------------------
# PR 行为
# -------------------------
PR_TITLE_PREFIX=[Coder]
# 可选：覆盖机器人提交代码时使用的 git author
GIT_AUTHOR_NAME=Coder
GIT_AUTHOR_EMAIL=coder-bot@local
SUBMIT_COMMENT_AFTER_PR=true
SUBMIT_COMMENT_BODY=/submit
DEFAULT_BASE_BRANCH=

# -------------------------
# 测试命令
# -------------------------
# 默认建议留空，由执行模型自行决定需要的最小验证。
TEST_COMMAND=

# -------------------------
# 调度
# -------------------------
DISPATCH_INTERVAL_SECONDS=5
FORK_WAIT_TIMEOUT_SECONDS=300
